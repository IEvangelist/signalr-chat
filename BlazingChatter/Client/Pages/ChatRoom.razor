<div class="chat-ambient flex h-full flex-col">
    <div class="mx-auto flex h-full w-full max-w-5xl flex-col border-x border-border/60 bg-background/30 backdrop-blur-sm">

        @* Chat top bar with a persistent live-connection indicator *@
        <div class="flex shrink-0 items-center justify-between gap-3 border-b border-border/70 px-4 py-2.5">
            <div class="flex min-w-0 items-center gap-2.5">
                <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10 text-primary">
                    <LucideIcon Name="messages-square" CssClass="h-4 w-4" />
                </span>
                <div class="min-w-0 leading-tight">
                    <p class="truncate text-sm font-semibold tracking-tight">Live chat room</p>
                    <p class="truncate text-xs text-muted-foreground">Shared with everyone online</p>
                </div>
            </div>
            <span class="inline-flex items-center gap-2 rounded-full border px-2.5 py-1 text-xs font-medium transition-colors @StatusPillClass">
                <span class="relative flex h-2 w-2">
                    <span class="absolute inline-flex h-full w-full rounded-full @StatusDotClass @(_connection is ConnectionStatus.Offline ? "" : "status-ping")"></span>
                    <span class="relative inline-flex h-2 w-2 rounded-full @StatusDotClass"></span>
                </span>
                @StatusLabel
            </span>
        </div>

        @* Message list *@
        <div id="message-scroll" class="min-h-0 flex-1 overflow-y-auto">
            <div class="flex w-full flex-col gap-4 px-4 py-5">
            @if (_messages.Count is 0)
            {
                <div class="flex flex-col items-center justify-center gap-4 py-20 text-center">
                    <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-primary/10 text-primary">
                        <LucideIcon Name="message-circle" CssClass="h-8 w-8" />
                    </div>
                    <div class="space-y-1">
                        <h2 class="text-lg font-semibold tracking-tight">Say hello</h2>
                        <p class="max-w-xs text-sm text-muted-foreground">
                            Messages are live for everyone in the room. Type below to get the conversation going.
                        </p>
                    </div>
                </div>
            }

            @foreach (var (id, message) in _messages)
            {
                @if (message.IsGreeting)
                {
                    <div class="msg-in flex justify-center py-1">
                        <div class="w-full max-w-xl rounded-2xl border border-primary/20 bg-card/70 p-4 shadow-sm backdrop-blur-sm">
                            <div class="mb-2.5 flex items-center gap-2.5">
                                <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10 text-primary">
                                    <LucideIcon Name="sparkles" CssClass="h-4 w-4" />
                                </span>
                                <div class="leading-tight">
                                    <p class="text-sm font-semibold tracking-tight">Command the chatbots</p>
                                    <p class="text-xs text-muted-foreground">A quick guide to get the jokes rolling</p>
                                </div>
                            </div>
                            <div class="greeting-content">@((MarkupString)message.Text)</div>
                        </div>
                    </div>
                }
                else
                {
                    var own = OwnsMessage(message.User);
                    <div id="@message.Id" class="@MessageInClass(own) flex items-end gap-2.5 @(own ? "flex-row-reverse" : "flex-row")">
                        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-xs font-semibold shadow-sm @AvatarClass(message, own)">
                            @if (message.IsChatBot)
                            {
                                <LucideIcon Name="bot" CssClass="h-4 w-4" />
                            }
                            else
                            {
                                @Initial(message.User)
                            }
                        </span>
                        <div class="flex min-w-0 max-w-[80%] flex-col @(own ? "items-end" : "items-start")">
                            <div class="mb-1 flex items-center gap-1.5 px-0.5 text-xs text-muted-foreground">
                                <span class="font-medium text-foreground/80">@(own ? "You" : message.User)</span>
                                @if (message.IsChatBot)
                                {
                                    <span class="inline-flex items-center gap-1 rounded bg-primary/10 px-1.5 py-px text-[10px] font-semibold uppercase tracking-wide text-primary">
                                        <LucideIcon Name="zap" CssClass="h-2.5 w-2.5" />bot
                                    </span>
                                }
                                <span class="tabular-nums text-[11px] text-muted-foreground/70">@TimeFor(message.Id)</span>
                            </div>
                            <div class="group relative rounded-2xl px-3.5 py-2 text-sm leading-relaxed shadow-sm transition @BubbleClass(message, own) @(own ? "cursor-pointer rounded-br-md" : "rounded-bl-md")"
                                 @onclick="@(async () => await StartEdit(message))">
                                <span class="whitespace-pre-wrap break-words">@((MarkupString)message.Text)</span>
                                @if (message.IsEdit)
                                {
                                    <span class="ml-1.5 align-middle text-[11px] opacity-70">(edited)</span>
                                }
                                @if (own)
                                {
                                    <span class="absolute -left-6 top-1/2 -translate-y-1/2 text-muted-foreground opacity-0 transition group-hover:opacity-100">
                                        <LucideIcon Name="pencil" CssClass="h-3.5 w-3.5" />
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

        @* Composer *@
        <div class="shrink-0 border-t border-border/70 bg-card/40 backdrop-blur-sm">
            <div class="w-full px-4 py-3">
            <div class="flex h-5 items-center gap-2 px-1 text-xs text-muted-foreground">
                @if (_usersTyping is { Count: > 0 })
                {
                    <span class="flex items-center gap-1">
                        <span class="typing-dot"></span>
                        <span class="typing-dot"></span>
                        <span class="typing-dot"></span>
                    </span>
                    <span>@TypingText</span>
                }
            </div>

            <div class="mt-1 rounded-xl border border-input bg-background p-1.5 shadow-sm transition focus-within:ring-2 focus-within:ring-ring">
                <input @ref="_messageInput" type="text" autocomplete="off"
                       class="w-full bg-transparent px-2.5 py-2 text-sm outline-none placeholder:text-muted-foreground"
                       placeholder="@(_messageId is null ? "Type a message..." : "Edit your message...")"
                       value="@_message" @oninput="OnInput"
                       @onkeyup="@(args => OnKeyUp(args))" />

                <div class="flex items-center justify-between gap-2 px-0.5 pt-1">
                    <div class="flex items-center gap-0.5">
                        @foreach (var emoji in _quickEmoji)
                        {
                            <button type="button" title="Add @emoji"
                                    class="flex h-8 w-8 items-center justify-center rounded-md text-lg leading-none transition hover:bg-accent active:scale-90"
                                    @onclick="@(() => AppendToMessage(emoji))">
                                @emoji
                            </button>
                        }
                        <span class="mx-1 h-5 w-px bg-border"></span>
                        <button type="button" title="Voice settings"
                                class="flex h-8 w-8 items-center justify-center rounded-md text-muted-foreground transition hover:bg-accent hover:text-foreground active:scale-90"
                                @onclick="OpenSettings">
                            <LucideIcon Name="settings" CssClass="h-4 w-4" />
                        </button>
                    </div>

                    <button type="button"
                            class="inline-flex h-9 items-center gap-1.5 rounded-lg bg-primary px-3.5 text-sm font-medium text-primary-foreground shadow-sm transition hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring active:scale-[0.97] disabled:pointer-events-none disabled:opacity-50"
                            disabled="@(string.IsNullOrWhiteSpace(_message))"
                            @onclick="@SendMessage">
                        @if (_messageId is null)
                        {
                            <span>Send</span>
                            <LucideIcon Name="send" CssClass="h-4 w-4" />
                        }
                        else
                        {
                            <span>Update</span>
                            <LucideIcon Name="check" CssClass="h-4 w-4" />
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
    </div>
</div>

@* Voice settings dialog *@
@if (_showSettings)
{
    <div class="fixed inset-0 z-[1200] flex items-center justify-center p-4">
        <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" @onclick="CloseSettings"></div>
        <div role="dialog" aria-modal="true"
             class="animate-message-in relative w-full max-w-md rounded-xl border border-border bg-card p-6 shadow-xl">
            <div class="mb-5 flex items-start justify-between">
                <div>
                    <h2 class="text-base font-semibold tracking-tight">Voice settings</h2>
                    <p class="mt-0.5 text-sm text-muted-foreground">Control how spoken messages are read aloud.</p>
                </div>
                <button type="button" @onclick="CloseSettings" aria-label="Close"
                        class="rounded-md p-1 text-muted-foreground transition hover:bg-accent hover:text-foreground">
                    <LucideIcon Name="x" CssClass="h-4 w-4" />
                </button>
            </div>

            <div class="space-y-5">
                <div class="space-y-2">
                    <div class="flex items-center justify-between">
                        <label for="voice-speed" class="text-sm font-medium">Voice speed</label>
                        <span class="rounded-md bg-muted px-2 py-0.5 font-mono text-xs text-muted-foreground">@VoiceSpeed.ToString("0.00")x</span>
                    </div>
                    <input id="voice-speed" type="range" class="w-full accent-primary"
                           min="@_voiceSpeeds.Min()" max="@_voiceSpeeds.Max()" step=".25"
                           value="@VoiceSpeed"
                           @onchange="@(args => VoiceSpeed = double.TryParse(args.Value?.ToString(), out var speed) ? speed : 1)" />
                </div>

                <div class="space-y-2">
                    <label for="voices" class="text-sm font-medium">Default voice</label>
                    <select id="voices" @bind="@Voice"
                            class="h-10 w-full rounded-md border border-input bg-background px-3 text-sm outline-none focus-visible:ring-2 focus-visible:ring-ring">
                        <option value="Auto">Auto (natural voice)</option>
                        @if (NaturalVoices is { Length: > 0 })
                        {
                            @foreach (var voice in NaturalVoices)
                            {
                                <option value="@voice.Name">@voice.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>

            <div class="mt-6 flex justify-end">
                <button type="button" @onclick="CloseSettings"
                        class="inline-flex h-9 items-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow-sm transition hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring active:scale-[0.98]">
                    Done
                </button>
            </div>
        </div>
    </div>
}
