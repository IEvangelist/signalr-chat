{
  "realm": "blazingchatter",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "verifyEmail": false,
  "displayName": "BlazingChatter",
  "clients": [
    {
      "clientId": "blazingchatter-web",
      "name": "BlazingChatter Web (Blazor WebAssembly)",
      "description": "Public PKCE client for the Blazor WebAssembly front end.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "https://localhost:7443/web/*",
        "http://localhost:7080/web/*"
      ],
      "webOrigins": [
        "https://localhost:7443",
        "http://localhost:7080"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "+"
      },
      "protocolMappers": [
        {
          "name": "blazingchatter-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "blazingchatter-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "tester",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Test",
      "lastName": "User",
      "email": "tester@blazingchatter.local",
      "credentials": [
        {
          "type": "password",
          "value": "Password123!",
          "temporary": false
        }
      ]
    }
  ]
}
